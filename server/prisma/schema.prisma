generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String             @unique
  password_hash     String
  full_name         String
  timezone          String             @default("UTC")
  is_paused         Boolean            @default(false)
  contacts          Contact[]
  templates         Template[]
  scheduledMessages ScheduledMessage[]
  notificationLogs  NotificationLog[]
  passwordResets    PasswordReset[]
  refreshTokens     RefreshToken[]
  created_at        DateTime           @default(now()) @db.Timestamptz
  updated_at        DateTime           @default(now()) @updatedAt @db.Timestamptz
  deleted_at        DateTime?          @db.Timestamptz

  @@map("users")
}

model Contact {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String             @db.Uuid
  first_name         String
  last_name          String?
  phone              String
  birthday_day       Int                @db.SmallInt
  birthday_month     Int                @db.SmallInt
  relationship_type  String             @default("friend")
  relationship_custom String?
  preferred_channel  String             @default("whatsapp")
  preferred_send_time DateTime          @default(dbgenerated("TIME '09:00:00'")) @db.Time
  timezone           String             @default("UTC")
  is_active          Boolean            @default(true)
  message_source     String
  message_body       String             @db.Text
  template_id        String?            @db.Uuid
  user               User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  template           Template?          @relation(fields: [template_id], references: [id], onDelete: SetNull)
  scheduledMessages  ScheduledMessage[]
  notificationLogs   NotificationLog[]
  created_at         DateTime           @default(now()) @db.Timestamptz
  updated_at         DateTime           @default(now()) @updatedAt @db.Timestamptz

  @@index([user_id])
  @@index([birthday_day, birthday_month])
  @@index([preferred_channel])
  @@index([template_id])
  @@map("contacts")
}

model Template {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String             @db.Uuid
  name           String
  body           String             @db.Text
  channel        String
  is_default     Boolean            @default(false)
  is_ai_generated Boolean           @default(false)
  user           User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  contacts       Contact[]
  scheduledMessages ScheduledMessage[]
  created_at     DateTime           @default(now()) @db.Timestamptz
  updated_at     DateTime           @default(now()) @updatedAt @db.Timestamptz

  @@unique([user_id, name])
  @@index([user_id])
  @@map("templates")
}

model ScheduledMessage {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String             @db.Uuid
  contact_id        String             @db.Uuid
  template_id       String?            @db.Uuid
  message_body      String             @db.Text
  channel           String
  job_type          String
  scheduled_for     DateTime           @db.Timestamptz
  status            String             @default("pending")
  attempt_count     Int                @default(0) @db.SmallInt
  last_attempted_at DateTime?          @db.Timestamptz
  sent_at           DateTime?          @db.Timestamptz
  error_message     String?
  user              User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  contact           Contact            @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  template          Template?          @relation(fields: [template_id], references: [id], onDelete: SetNull)
  notificationLogs  NotificationLog[]
  created_at        DateTime           @default(now()) @db.Timestamptz
  updated_at        DateTime           @default(now()) @updatedAt @db.Timestamptz

  @@index([user_id])
  @@index([contact_id])
  @@index([template_id])
  @@index([status])
  @@index([scheduled_for])
  @@map("scheduled_messages")
}

model NotificationLog {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduled_message_id String?            @db.Uuid
  user_id              String?            @db.Uuid
  contact_id           String?            @db.Uuid
  channel              String
  job_type             String
  status               String
  provider             String?
  provider_message_id  String?
  provider_response    Json?
  error_message        String?
  sent_at              DateTime           @default(now()) @db.Timestamptz
  scheduled_message    ScheduledMessage?  @relation(fields: [scheduled_message_id], references: [id], onDelete: SetNull)
  user                 User?              @relation(fields: [user_id], references: [id], onDelete: SetNull)
  contact              Contact?           @relation(fields: [contact_id], references: [id], onDelete: SetNull)
  created_at           DateTime           @default(now()) @db.Timestamptz

  @@index([scheduled_message_id])
  @@index([user_id])
  @@index([contact_id])
  @@index([status])
  @@map("notification_logs")
}

model PasswordReset {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token      String    @unique
  expires_at DateTime  @db.Timestamptz
  used_at    DateTime? @db.Timestamptz
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at DateTime  @default(now()) @db.Timestamptz

  @@index([user_id])
  @@map("password_resets")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token      String    @unique
  expires_at DateTime  @db.Timestamptz
  revoked_at DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_tokens")
}
